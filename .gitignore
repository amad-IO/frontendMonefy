# =============================================
# .gitignore — Monefy Flutter Mobile App
# =============================================

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# =============================================
# IDE — IntelliJ / Android Studio
# =============================================
*.iml
*.ipr
*.iws
.idea/

# =============================================
# IDE — VS Code
# =============================================
.vscode/

# =============================================
# Flutter / Dart / Pub
# =============================================
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/
.packages

# =============================================
# Platform yang TIDAK dipakai (mobile only)
# =============================================
/web/
/macos/
/linux/
/windows/

# =============================================
# Android build artifacts
# =============================================
/android/app/debug
/android/app/profile
/android/app/release
/android/.gradle/
/android/local.properties
*.apk
*.aab

# =============================================
# Symbolication & Obfuscation
# =============================================
app.*.symbols
app.*.map.json

# =============================================
# OS generated files
# =============================================
Thumbs.db
ehthumbs.db
Desktop.ini
*.tmp
*.bak
*.swp
*~
